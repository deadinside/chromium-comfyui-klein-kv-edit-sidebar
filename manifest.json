{
  "manifest_version": 3,
  "name": "Klein KV Edit",
  "version": "1.0.0",
  "description": "Right-click image → Send to Klein KV Edit → Sidebar editing panel.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Klein KV Edit",
    "default_icon": {
      "128": "assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "options_page": "options/options.html",
  "icons": {
    "128": "assets/icon128.png"
  }
}
